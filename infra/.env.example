# Development environment. Copy to infra/.env (gitignored) and adjust.
APP_ENV=development
APP_PORT=8080

# Database
POSTGRES_DB=artist_portfolio
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@postgres:5432/artist_portfolio?sslmode=disable

# Auth — replace JWT_SECRET with a long random value before any non-local use.
JWT_SECRET=dev-only-secret-replace-before-production-at-least-32-characters
JWT_EXPIRES_IN=12h
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Local uploads (development). In production S3_ENDPOINT is required instead.
UPLOAD_DIR=/app/uploads

# S3-compatible object storage (leave empty in development to use local disk).
S3_ENDPOINT=
S3_REGION=eu-central-1
S3_BUCKET=artist-portfolio
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# Frontend
API_INTERNAL_URL=http://backend:8080/api/v1
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_IMAGE_HOST=

# Telegram notifications for new orders. Empty token/chat id or false disables them.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFICATIONS_ENABLED=false
PUBLIC_SITE_URL=http://localhost:3000
