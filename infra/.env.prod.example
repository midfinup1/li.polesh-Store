APP_ENV=production
APP_PORT=8080

DOMAIN=lipolesh.art
WWW_DOMAIN=www.lipolesh.art

FRONTEND_URL=https://lipolesh.art
NEXT_PUBLIC_SITE_URL=https://lipolesh.art
NEXT_PUBLIC_API_URL=/api/v1
API_INTERNAL_URL=http://backend:8080/api/v1
CORS_ALLOWED_ORIGINS=https://lipolesh.art,https://www.lipolesh.art

POSTGRES_DB=artist_portfolio
POSTGRES_USER=artist_user
POSTGRES_PASSWORD=
DATABASE_URL=

JWT_SECRET=

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

S3_ENDPOINT=s3.twcstorage.ru
S3_REGION=ru-1
S3_BUCKET=332f0fae-cd27-4aa5-b0b7-e21c7ebf02a5
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=https://s3.twcstorage.ru/332f0fae-cd27-4aa5-b0b7-e21c7ebf02a5

ENABLE_SWAP=true
SWAP_SIZE=2G

ENABLE_BACKUP_CRON=true

# Off-site PostgreSQL backups to S3
BACKUP_S3_ENABLED=false
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=backups/postgres
BACKUP_RETENTION_DAYS=30
S3_SCHEME=https
# Telegram notifications for new orders. Empty token/chat id or false disables them.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFICATIONS_ENABLED=false
PUBLIC_SITE_URL=https://lipolesh.art

# Analytics events older than this number of days are deleted automatically.
ANALYTICS_RETENTION_DAYS=365

# Additional HTTPS image hosts allowed by Next.js image optimizer.
NEXT_IMAGE_REMOTE_HOSTS=3mjjbew73k.cdn.twcstorage.ru
