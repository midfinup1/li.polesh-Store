DOMAIN=example.com
APP_ENV=production
APP_PORT=8080
GITHUB_REPOSITORY=midfinup1/li.polesh-Store
IMAGE_TAG=latest
POSTGRES_DB=artist_portfolio
POSTGRES_USER=artist_app
POSTGRES_PASSWORD=replace-with-long-random-password
DATABASE_URL=postgres://artist_app:replace-with-long-random-password@postgres:5432/artist_portfolio?sslmode=disable
JWT_SECRET=replace-with-random-secret-longer-than-32-characters
JWT_EXPIRES_IN=12h
CORS_ALLOWED_ORIGINS=https://example.com
S3_ENDPOINT=s3.example-object-storage.com
S3_REGION=eu-central-1
S3_BUCKET=artist-portfolio
S3_ACCESS_KEY=replace-me
S3_SECRET_KEY=replace-me
S3_PUBLIC_URL=https://cdn.example.com/artist-portfolio
MAIL_FROM=Portfolio <orders@example.com>
MAIL_TO=artist@example.com
RESEND_API_KEY=replace-me
API_INTERNAL_URL=http://backend:8080/api/v1
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_IMAGE_HOST=cdn.example.com
