{
	order rate_limit before reverse_proxy
}

{$DOMAIN} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}

	@immutable path /_next/static/*
	header @immutable Cache-Control "public, max-age=31536000, immutable"

	@apiWrites {
		path /api/v1/*
		method POST PUT PATCH DELETE
	}
	rate_limit @apiWrites {
		zone api_writes {
			key {remote_host}
			events 120
			window 1m
		}
	}

	@loginWrites {
		path /api/v1/auth/login
		method POST
	}
	rate_limit @loginWrites {
		zone login_writes {
			key {remote_host}
			events 10
			window 1m
		}
	}

	@orderWrites {
		path /api/v1/orders
		method POST
	}
	rate_limit @orderWrites {
		zone order_writes {
			key {remote_host}
			events 10
			window 1h
		}
	}

	@analyticsWrites {
		path /api/v1/analytics/view
		method POST
	}
	rate_limit @analyticsWrites {
		zone analytics_writes {
			key {remote_host}
			events 60
			window 1m
		}
	}

	handle /api/v1/* {
		reverse_proxy backend:8080
	}

	handle /uploads/* {
		reverse_proxy backend:8080
	}

	# Public media proxy for S3 objects.
	# Example:
	# /media/artworks/4/file_display.webp
	# -> https://s3.twcstorage.ru/<S3_BUCKET>/artworks/4/file_display.webp
	handle_path /media/* {
		@mediaMethods method GET HEAD

		handle @mediaMethods {
			rewrite * /{$S3_BUCKET}{uri}

			reverse_proxy https://{$S3_ENDPOINT} {
				header_up Host {$S3_ENDPOINT}
				header_down -X-Robots-Tag
				header_down Cache-Control "public, max-age=31536000, immutable"
			}
		}

		respond 405
	}

	handle {
		reverse_proxy frontend:3000
	}

	handle_errors {
		@maintenance expression `{err.status_code} in [502, 503, 504]`

		handle @maintenance {
			root * /srv
			rewrite * /maintenance.html
			file_server
		}

		respond "Service unavailable" {err.status_code}
	}

	log {
		output stdout
		format json
	}
}

www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
}
